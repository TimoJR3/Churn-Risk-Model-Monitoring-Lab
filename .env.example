APP_NAME="Churn Risk & Model Monitoring Lab"
APP_ENV=local
API_BASE_URL=http://api:8000

POSTGRES_USER=churn_user
POSTGRES_PASSWORD=churn_password
POSTGRES_DB=churn_lab
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://churn_user:churn_password@postgres:5432/churn_lab

PREDICTION_THRESHOLD=0.5
MAX_BATCH_SIZE=100
SAVE_PREDICTIONS=true
